---
import Icon from './Icon.astro';
import SkillIcon from './SkillIcon.astro';
import dailyDosePreview from '../assets/daily-dose.png';
import pinkTechPreview from '../assets/pink-tech.png';

const projects = [
  {
    title: 'PinkTech',
    description: 'A platform for discovering inspiring women in tech.',
    image: pinkTechPreview,
    techStack: ['React', 'TypeScript', 'Tailwind CSS'],
    deployment: 'https://pinktech.vercel.app/',
    github: 'https://github.com/nhcarrigan-mentorship/pink-tech',
  },
  {
    title: 'Daily Dose',
    description: 'A full-stack platform for daily affirmations and positive self-talk.',
    image: dailyDosePreview,
    techStack: ['HTML', 'CSS', 'JavaScript', 'Flask'],
    github: 'https://github.com/freeCodeCamp-2025-Summer-Hackathon/indigo-class#',
  },
];
---

<section id="projects" class="py-8 px-6 md:py-20">
  <div class="max-w-6xl mx-auto space-y-6 md:space-y-10">
    <div class="space-y-2">
      <h2 class="text-3xl font-medium text-foreground sm:text-4xl">Projects</h2>
      <div class="w-20 h-1 bg-primary rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {
        projects.map((project) => (
          <div class="themed-section-card flex h-full flex-col overflow-hidden bg-card/80 backdrop-blur-sm border border-secondary/70 rounded-xl hover:shadow-xl transition-all group dark:border-primary/25">
            {project.deployment ? (
              <a
                href={project.deployment}
                target="_blank"
                rel="noopener noreferrer"
                class="block aspect-[16/10] overflow-hidden bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
                aria-label={`Open ${project.title} deployed app`}
              >
                <img
                  src={project.image.src}
                  alt={`${project.title} project preview`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </a>
            ) : (
              <div class="aspect-[16/10] overflow-hidden bg-accent">
                <img
                  src={project.image.src}
                  alt={`${project.title} project preview`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            )}

            <div class="flex flex-1 flex-col p-6 space-y-4">
              <h3 class="text-lg font-medium text-foreground group-hover:text-primary transition-colors sm:text-xl">
                {project.title}
              </h3>

              <p class="text-muted-foreground leading-relaxed">
                {project.description}
              </p>

              <div class="flex flex-wrap gap-2">
                {project.techStack.map((tech) => (
                  <span class="px-3 py-1 bg-accent text-accent-foreground text-sm rounded-md border border-secondary/60 flex items-center gap-1.5 dark:bg-[var(--pink-soft)] dark:text-white dark:border-primary/30">
                    <SkillIcon name={tech} />
                    {tech}
                  </span>
                ))}
              </div>

              <div class="mt-auto flex flex-row flex-wrap gap-3 pt-2">
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex min-h-11 flex-1 items-center justify-center gap-2 rounded-lg border border-primary/30 bg-card/80 px-3 py-2.5 text-sm font-medium text-primary shadow-sm transition-all hover:border-primary hover:bg-primary hover:text-primary-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 cursor-pointer sm:min-h-12 sm:flex-none sm:px-5 sm:py-3 sm:text-base dark:bg-[var(--pink-medium)] dark:text-white dark:hover:bg-[var(--pink-accent)] dark:hover:text-white"
                  >
                    <Icon name="github" class="h-4 w-4 shrink-0" />
                    Code
                  </a>
                )}
                {project.deployment && (
                  <a
                    href={project.deployment}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex min-h-11 flex-1 items-center justify-center gap-2 rounded-lg bg-primary px-3 py-2.5 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-[var(--primary-hover)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 cursor-pointer sm:min-h-12 sm:flex-none sm:px-5 sm:py-3 sm:text-base"
                  >
                    <Icon name="globe" class="h-4 w-4 shrink-0" />
                    Live Demo
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
