---
import profilePhoto from '../assets/rain.jpg';
import Icon from './Icon.astro';
import { contact, mailto } from '../data/contact';
---

<section class="min-h-screen flex items-center justify-center px-6 py-20 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-white via-[#ffe6ef]/20 to-white pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="flex md:hidden items-center justify-center mb-8">
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-[#ffe6ef] to-[#ffc4d6] rounded-3xl opacity-20 blur-2xl scale-105"></div>
        <img
          src={profilePhoto.src}
          alt="Rain - Frontend Developer and Developer Advocate"
          class="relative w-48 h-48 object-cover rounded-3xl shadow-xl"
        />
      </div>
    </div>

    <div class="grid md:grid-cols-[1.2fr_1fr] gap-12 items-center">
      <div class="space-y-8">
        <div class="space-y-4">
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-medium leading-tight text-foreground">
            Frontend developer building practical web apps and community-driven experiences.
          </h1>
          <p class="text-base sm:text-lg text-muted-foreground leading-relaxed">
            I create user-focused projects, learn in public, and explore technology through teaching, speaking, and real-world collaboration.
          </p>
        </div>

        <div class="flex flex-wrap gap-4">
          <button
            type="button"
            data-scroll-to="projects"
            class="px-8 py-3 bg-primary text-primary-foreground rounded-lg hover:opacity-90 transition-opacity flex items-center gap-2 shadow-sm cursor-pointer"
          >
            View Projects
            <Icon name="arrow-right" class="w-4 h-4" />
          </button>
          <button
            type="button"
            data-scroll-to="contact"
            class="px-8 py-3 bg-secondary/30 text-foreground rounded-lg hover:bg-secondary/50 transition-colors cursor-pointer"
          >
            Let's Connect
          </button>
        </div>

        <div class="flex items-center gap-4">
          <a
            href={contact.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-12 w-12 items-center justify-center rounded-lg border border-white/70 bg-white/80 text-foreground shadow-sm transition-all hover:border-primary hover:bg-white hover:text-primary hover:ring-2 hover:ring-primary/30 cursor-pointer sm:h-14 sm:w-14"
            aria-label="GitHub"
          >
            <Icon name="github" class="w-7 h-7 sm:w-8 sm:h-8" />
          </a>
          <a
            href={contact.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-12 w-12 items-center justify-center rounded-lg border border-white/70 bg-white/80 text-foreground shadow-sm transition-all hover:border-primary hover:bg-white hover:text-primary hover:ring-2 hover:ring-primary/30 cursor-pointer sm:h-14 sm:w-14"
            aria-label="LinkedIn"
          >
            <Icon name="linkedin" class="w-7 h-7 sm:w-8 sm:h-8" />
          </a>
          <a
            href={mailto}
            class="flex h-12 w-12 items-center justify-center rounded-lg border border-white/70 bg-white/80 text-foreground shadow-sm transition-all hover:border-primary hover:bg-white hover:text-primary hover:ring-2 hover:ring-primary/30 cursor-pointer sm:h-14 sm:w-14"
            aria-label="Email"
          >
            <Icon name="mail" class="w-7 h-7 sm:w-8 sm:h-8" />
          </a>
        </div>

        <p class="text-sm text-muted-foreground">
          Open to DevRel and frontend opportunities
        </p>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-[#ffe6ef] to-[#ffc4d6] rounded-3xl opacity-20 blur-2xl scale-105"></div>
          <img
            src={profilePhoto.src}
            alt="Rain - Frontend Developer and Developer Advocate"
            class="relative w-80 h-80 object-cover rounded-3xl shadow-xl"
          />
        </div>
      </div>
    </div>
  </div>
</section>
