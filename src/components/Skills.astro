---
import SkillIcon from './SkillIcon.astro';

const skillCategories = [
  {
    title: 'Frontend Development',
    skills: [
      { name: 'React' },
      { name: 'TypeScript' },
      { name: 'JavaScript' },
      { name: 'HTML' },
      { name: 'CSS' },
      { name: 'Tailwind CSS' },
    ],
  },
  {
    title: 'Tools & Technologies',
    skills: [
      { name: 'Git' },
      { name: 'GitHub' },
      { name: 'Vite' },
      { name: 'Vitest' },
      { name: 'Firebase' },
      { name: 'Supabase' },
      { name: 'Vercel' },
      { name: 'Chrome DevTools' },
    ],
  },
  {
    title: 'Developer Relations',
    skills: [
      { name: 'Public Speaking' },
      { name: 'Technical Writing' },
      { name: 'Workshop Facilitation' },
      { name: 'Community Building' },
      { name: 'Content Creation' },
      { name: 'Documentation' },
    ],
  },
  {
    title: 'Best Practices',
    skills: [
      { name: 'Accessibility (WCAG)' },
      { name: 'Responsive Design' },
      { name: 'Web Performance' },
      { name: 'SEO' },
      { name: 'Testing' },
      { name: 'Code Review' },
      { name: 'Agile Development' },
    ],
  },
];
---

<section id="skills" class="py-8 px-6 md:py-20">
  <div class="max-w-6xl mx-auto space-y-6 md:space-y-10">
    <div class="space-y-2">
      <h2 class="text-3xl font-medium text-foreground sm:text-4xl">Skills & Expertise</h2>
      <div class="w-20 h-1 bg-primary rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-6 md:gap-8">
      {
        skillCategories.map((category) => (
          <div class="themed-section-card bg-card/80 backdrop-blur-sm border border-border rounded-xl p-8 hover:shadow-xl transition-all space-y-4 dark:border-primary/25">
            <h3 class="text-lg font-medium text-foreground sm:text-xl">
              {category.title}
            </h3>

            <div class="flex flex-wrap gap-2">
              {category.skills.map((skill) => (
                <span class="px-3 py-1.5 sm:px-4 sm:py-2 bg-accent text-accent-foreground rounded-lg border border-transparent text-[11px] sm:text-sm flex items-center gap-1.5 dark:bg-[var(--pink-soft)] dark:text-white dark:border-primary/30">
                  <SkillIcon name={skill.name} class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-accent-foreground dark:text-white" />
                  {skill.name}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
