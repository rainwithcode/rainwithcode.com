---
import Icon from './Icon.astro';

const experiences = [
  {
    role: 'Event Lead',
    organization: 'freeCodeCamp',
    location: 'Remote',
    startDate: '2026-05',
    endDate: null,
    description: 'Train and support 7 event coordinators serving a global developer community of 40,000+ Discord members',
    icon: 'briefcase',
  },
  {
    role: 'Freelance Frontend Developer',
    organization: 'Rain With Code',
    location: 'Remote',
    startDate: '2026-03',
    endDate: null,
    description: 'Develop and maintain a client website, implementing responsive and accessible user interfaces',
    icon: 'briefcase',
  },
  {
    role: 'Founder and Community Lead',
    organization: 'Devite',
    location: 'Cavite, Philippines',
    startDate: '2026-03',
    endDate: null,
    description: 'Founded and lead a 5-member developer group focused on frontend development, pair programming, and collaborative learning',
    icon: 'briefcase',
  },
  {
    role: 'General Equivalency Diploma',
    organization: 'Education',
    startDate: '2023-01',
    icon: 'book-open',
  },
];

const formatDate = (date: string) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(`${date}-01T00:00:00Z`));

const formatDateRange = (startDate: string, endDate?: string | null) => {
  if (endDate === undefined) {
    return formatDate(startDate);
  }

  return `${formatDate(startDate)} - ${endDate ? formatDate(endDate) : 'Present'}`;
};
---

<section id="experience" class="py-8 px-6 md:py-20 bg-muted/30">
  <div class="max-w-6xl mx-auto space-y-6 md:space-y-10">
    <div class="space-y-2">
      <h2 class="text-3xl font-medium text-foreground sm:text-4xl">Experience</h2>
      <div class="w-20 h-1 bg-primary rounded-full"></div>
    </div>

    <div class="space-y-6">
      {
        experiences.map((exp) => (
          <div class="bg-white/80 backdrop-blur-sm border border-white/20 rounded-xl p-4 sm:p-6 hover:shadow-xl hover:bg-white/90 transition-all">
            <div class="flex items-start gap-3 sm:gap-4">
              <div class="w-9 h-9 sm:w-11 sm:h-11 bg-accent rounded-lg text-black flex-shrink-0 flex items-center justify-center p-2 sm:p-3">
                <Icon name={exp.icon ?? 'briefcase'} />
              </div>

              <div class="flex-1 space-y-2">
                <div class="flex flex-col items-start gap-1 sm:flex-row sm:justify-between sm:gap-4">
                  <div>
                    <h3 class="text-base sm:text-xl font-medium text-foreground">
                      {exp.role}
                    </h3>
                    <p class="text-sm sm:text-base text-muted-foreground">
                      {exp.organization}
                      {exp.location && <span> · {exp.location}</span>}
                    </p>
                  </div>
                  <span class="text-xs sm:text-sm text-muted-foreground whitespace-nowrap">
                    {formatDateRange(exp.startDate, exp.endDate)}
                  </span>
                </div>

                {exp.description && (
                  <p class="text-sm sm:text-base text-muted-foreground leading-relaxed">
                    {exp.description}
                  </p>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
