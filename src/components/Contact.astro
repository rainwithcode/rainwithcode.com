---
import Icon from './Icon.astro';
import { contact, mailto } from '../data/contact';
---

<section id="contact" class="py-16 px-6 md:py-20 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-white via-[#ffe6ef]/20 to-white pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid md:grid-cols-2 gap-8 md:gap-10 items-start">
      <div class="space-y-8">
        <div class="space-y-2">
          <p class="text-primary text-base font-medium sm:text-lg">Let's talk</p>
          <h2 class="text-3xl font-medium text-foreground sm:text-4xl">Contact</h2>
          <div class="w-20 h-1 bg-primary rounded-full"></div>
        </div>

        <div class="space-y-4">
          <p class="text-base text-foreground/80 leading-relaxed sm:text-lg">
            Have a question or a project in mind? Feel free to reach out.
          </p>

          <div>
            <p class="text-sm text-primary font-medium mb-1">Email:</p>
            <a
              href={mailto}
              class="text-base text-foreground hover:text-primary transition-colors cursor-pointer font-medium sm:text-lg"
            >
              {contact.email}
            </a>
          </div>
        </div>

        <div class="flex flex-nowrap gap-4 pt-4">
          <a
            href={contact.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="flex h-14 w-14 items-center justify-center border border-border bg-white text-foreground rounded-lg hover:border-primary hover:text-primary hover:ring-2 hover:ring-primary/20 transition-all cursor-pointer shadow-sm lg:h-auto lg:w-auto lg:gap-3 lg:px-6 lg:py-3"
          >
            <Icon name="github" class="w-8 h-8 lg:w-7 lg:h-7" />
            <span class="sr-only lg:not-sr-only">GitHub</span>
          </a>

          <a
            href={contact.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="flex h-14 w-14 items-center justify-center border border-border bg-white text-foreground rounded-lg hover:border-primary hover:text-primary hover:ring-2 hover:ring-primary/20 transition-all cursor-pointer shadow-sm lg:h-auto lg:w-auto lg:gap-3 lg:px-6 lg:py-3"
          >
            <Icon name="linkedin" class="w-8 h-8 lg:w-7 lg:h-7" />
            <span class="sr-only lg:not-sr-only">LinkedIn</span>
          </a>

          <a
            href={mailto}
            aria-label="Email"
            class="flex h-14 w-14 items-center justify-center border border-border bg-white text-foreground rounded-lg hover:border-primary hover:text-primary hover:ring-2 hover:ring-primary/20 transition-all cursor-pointer shadow-sm lg:h-auto lg:w-auto lg:gap-3 lg:px-6 lg:py-3"
          >
            <Icon name="mail" class="w-8 h-8 lg:w-7 lg:h-7" />
            <span class="sr-only lg:not-sr-only">Email</span>
          </a>
        </div>
      </div>

      <div class="rounded-2xl bg-gradient-to-br from-[#ffe6ef] via-[#ffc4d6] to-[#ffb3cc] p-6 shadow-xl ring-1 ring-white/70 sm:p-8">
        <form
          id="contact-form"
          action="https://formspree.io/f/xeeqajvb"
          method="POST"
          class="space-y-6"
        >
          <div>
            <label for="name" class="block text-sm font-semibold text-foreground mb-2">
              Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              autocomplete="name"
              placeholder="Jane Doe"
              required
              class="w-full px-4 py-3 bg-white/95 border border-white/80 text-foreground placeholder:text-muted-foreground rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-white transition-all cursor-text"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-foreground mb-2">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              placeholder="jane@example.com"
              required
              class="w-full px-4 py-3 bg-white/95 border border-white/80 text-foreground placeholder:text-muted-foreground rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-white transition-all cursor-text"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-foreground mb-2">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              placeholder="Hi Rain, I came across your portfolio and would love to discuss..."
              required
              rows="6"
              aria-describedby="message-help"
              class="w-full px-4 py-3 bg-white/95 border border-white/80 text-foreground placeholder:text-muted-foreground rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-white transition-all resize-none cursor-text"
            ></textarea>
            <p id="message-help" class="mt-2 text-sm text-foreground/70">
              Share a few details so I can reply with the right context.
            </p>
          </div>

          <input type="hidden" name="_subject" value="New portfolio message" />

          <button
            id="contact-submit-button"
            type="submit"
            class="w-full px-8 py-4 bg-primary text-primary-foreground rounded-lg hover:opacity-90 transition-opacity shadow-sm cursor-pointer font-medium"
          >
            Submit
          </button>

          <p id="contact-status" class="text-sm text-foreground/80" role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script type="module">
  const form = document.getElementById('contact-form');
  const submitButton = document.getElementById('contact-submit-button');
  const statusMessage = document.getElementById('contact-status');

  if (form && submitButton && statusMessage) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const url = form.action;

      submitButton.disabled = true;
      submitButton.textContent = 'Sending...';
      statusMessage.textContent = '';

      try {
        const response = await fetch(url, {
          method: 'POST',
          body: formData,
          headers: {
            Accept: 'application/json',
          },
        });

        if (!response.ok) {
          throw new Error('Form submission failed.');
        }

        form.reset();
        submitButton.textContent = '✓ Submitted';
        submitButton.classList.add('opacity-90', 'cursor-default');
        submitButton.classList.remove('hover:opacity-90');
        statusMessage.textContent = 'Thanks! Rain has received your message.';

        setTimeout(() => {
          submitButton.disabled = false;
          submitButton.textContent = 'Submit';
          submitButton.classList.remove('opacity-90', 'cursor-default');
          submitButton.classList.add('hover:opacity-90');
          statusMessage.textContent = '';
        }, 3000);
      } catch (error) {
        submitButton.disabled = false;
        submitButton.textContent = 'Submit';
        statusMessage.textContent = 'Something went wrong. Please try again or email directly.';
      }
    });
  }
</script>
