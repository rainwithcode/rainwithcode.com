---
import Icon from './Icon.astro';
import { contact, mailto } from '../data/contact';
---

<section id="contact" class="py-10 px-6 md:py-20 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-background via-accent/20 to-background pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-start">
      <div class="space-y-8">
        <div class="space-y-2">
          <p class="text-primary text-base font-medium sm:text-lg">Let's talk</p>
          <h2 class="text-3xl font-medium text-foreground sm:text-4xl">Contact</h2>
          <div class="w-20 h-1 bg-primary rounded-full"></div>
        </div>

        <div class="space-y-4">
          <p class="text-base text-foreground/80 leading-relaxed sm:text-lg">
            Have a question or a project in mind? Feel free to reach out.
          </p>

          <div>
            <p class="text-sm text-primary font-medium mb-1">Email:</p>
            <a
              href={mailto}
              class="text-base text-foreground hover:text-primary transition-colors cursor-pointer font-medium sm:text-lg"
            >
              {contact.email}
            </a>
          </div>
        </div>

        <div class="flex flex-nowrap gap-4 pt-4">
          <a
            href={contact.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="flex h-14 w-14 items-center justify-center border border-border bg-card text-foreground rounded-lg hover:border-primary hover:text-primary hover:ring-2 hover:ring-primary/20 transition-all cursor-pointer shadow-sm lg:h-auto lg:w-auto lg:gap-3 lg:px-6 lg:py-3"
          >
            <Icon name="github" class="w-8 h-8 lg:w-7 lg:h-7" />
            <span class="sr-only lg:not-sr-only">GitHub</span>
          </a>

          <a
            href={contact.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="flex h-14 w-14 items-center justify-center border border-border bg-card text-foreground rounded-lg hover:border-primary hover:text-primary hover:ring-2 hover:ring-primary/20 transition-all cursor-pointer shadow-sm lg:h-auto lg:w-auto lg:gap-3 lg:px-6 lg:py-3"
          >
            <Icon name="linkedin" class="w-8 h-8 lg:w-7 lg:h-7" />
            <span class="sr-only lg:not-sr-only">LinkedIn</span>
          </a>

          <a
            href={mailto}
            aria-label="Email"
            class="flex h-14 w-14 items-center justify-center border border-border bg-card text-foreground rounded-lg hover:border-primary hover:text-primary hover:ring-2 hover:ring-primary/20 transition-all cursor-pointer shadow-sm lg:h-auto lg:w-auto lg:gap-3 lg:px-6 lg:py-3"
          >
            <Icon name="mail" class="w-8 h-8 lg:w-7 lg:h-7" />
            <span class="sr-only lg:not-sr-only">Email</span>
          </a>
        </div>
      </div>

      <div class="rounded-2xl border border-primary/20 bg-[var(--pink-soft)] p-4 shadow-xl ring-1 ring-border sm:p-8 dark:border-primary/25">
        <form
          id="contact-form"
          action="https://formspree.io/f/xeeqajvb"
          method="POST"
          class="space-y-4 sm:space-y-6"
        >
          <div class="grid gap-3 sm:grid-cols-2 sm:gap-4">
            <div>
              <label for="first-name" class="mb-1.5 block text-xs font-semibold text-foreground sm:mb-2 sm:text-sm">
                First name
              </label>
              <input
                type="text"
                id="first-name"
                name="first_name"
                autocomplete="given-name"
                placeholder="Jane"
                required
                class="w-full rounded-lg border border-border bg-card/95 px-3 py-2.5 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50 cursor-text sm:px-4 sm:py-3 sm:text-base"
              />
            </div>

            <div>
              <label for="last-name" class="mb-1.5 block text-xs font-semibold text-foreground sm:mb-2 sm:text-sm">
                Last name
              </label>
              <input
                type="text"
                id="last-name"
                name="last_name"
                autocomplete="family-name"
                placeholder="Doe"
                required
                class="w-full rounded-lg border border-border bg-card/95 px-3 py-2.5 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50 cursor-text sm:px-4 sm:py-3 sm:text-base"
              />
            </div>
          </div>

          <div>
            <label for="email" class="mb-1.5 block text-xs font-semibold text-foreground sm:mb-2 sm:text-sm">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              placeholder="jane@example.com"
              required
              class="w-full rounded-lg border border-border bg-card/95 px-3 py-2.5 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50 cursor-text sm:px-4 sm:py-3 sm:text-base"
            />
          </div>

          <div>
            <label for="phone" class="mb-1.5 block text-xs font-semibold text-foreground sm:mb-2 sm:text-sm">
              Phone number
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              autocomplete="tel"
              placeholder=" +1 555-555-0199"
              class="w-full rounded-lg border border-border bg-card/95 px-3 py-2.5 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50 cursor-text sm:px-4 sm:py-3 sm:text-base"
            />
          </div>

          <div>
            <label for="message" class="mb-1.5 block text-xs font-semibold text-foreground sm:mb-2 sm:text-sm">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              placeholder="Hi Rain, I came across your portfolio and would love to discuss..."
              required
              rows="5"
              aria-describedby="message-help"
              class="w-full rounded-lg border border-border bg-card/95 px-3 py-2.5 text-sm text-foreground shadow-sm transition-all resize-none placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50 cursor-text sm:px-4 sm:py-3 sm:text-base"
            ></textarea>
          </div>

          <fieldset class="space-y-2 sm:space-y-3">
            <legend class="text-xs font-semibold text-foreground sm:text-sm">Services</legend>
            <div class="grid gap-2.5 sm:grid-cols-2 sm:gap-3">
              <label class="flex items-center gap-2.5 text-sm font-medium text-foreground cursor-pointer sm:gap-3">
                <input
                  type="checkbox"
                  name="services"
                  value="Website Development"
                  class="h-4 w-4 rounded border-border bg-card text-primary focus:ring-primary/50 cursor-pointer"
                />
                Website Development
              </label>

              <label class="flex items-center gap-2.5 text-sm font-medium text-foreground cursor-pointer sm:gap-3">
                <input
                  type="checkbox"
                  name="services"
                  value="Community & Event Management"
                  class="h-4 w-4 rounded border-border bg-card text-primary focus:ring-primary/50 cursor-pointer"
                />
                Community &amp; Event Management
              </label>

              <label class="flex items-center gap-2.5 text-sm font-medium text-foreground cursor-pointer sm:gap-3">
                <input
                  type="checkbox"
                  name="services"
                  value="Speaking & Workshops"
                  class="h-4 w-4 rounded border-border bg-card text-primary focus:ring-primary/50 cursor-pointer"
                />
                Speaking &amp; Workshops
              </label>
            </div>
          </fieldset>

          <input type="hidden" name="_subject" value="New portfolio message" />

          <button
            id="contact-submit-button"
            type="submit"
            class="w-full rounded-lg bg-primary px-8 py-3 text-sm font-medium text-primary-foreground shadow-sm transition-opacity hover:opacity-90 cursor-pointer sm:py-4 sm:text-base"
          >
            Send message
          </button>

          <p id="contact-status" class="text-xs text-foreground/80 sm:text-sm" role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script type="module">
  const form = document.getElementById('contact-form');
  const submitButton = document.getElementById('contact-submit-button');
  const statusMessage = document.getElementById('contact-status');

  if (form && submitButton && statusMessage) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const url = form.action;

      submitButton.disabled = true;
      submitButton.textContent = 'Sending...';
      statusMessage.textContent = '';

      try {
        const response = await fetch(url, {
          method: 'POST',
          body: formData,
          headers: {
            Accept: 'application/json',
          },
        });

        if (!response.ok) {
          throw new Error('Form submission failed.');
        }

        form.reset();
        submitButton.textContent = '✓ Submitted';
        submitButton.classList.add('opacity-90', 'cursor-default');
        submitButton.classList.remove('hover:opacity-90');
        statusMessage.textContent = 'Thanks! Rain has received your message.';

        setTimeout(() => {
          submitButton.disabled = false;
          submitButton.textContent = 'Send message';
          submitButton.classList.remove('opacity-90', 'cursor-default');
          submitButton.classList.add('hover:opacity-90');
          statusMessage.textContent = '';
        }, 3000);
      } catch (error) {
        submitButton.disabled = false;
        submitButton.textContent = 'Send message';
        statusMessage.textContent = 'Something went wrong. Please try again or email directly.';
      }
    });
  }
</script>
