---
import Icon from './Icon.astro';
---

<button
  type="button"
  data-scroll-to-top
  data-scroll-to="top"
  class="fixed bottom-8 right-8 z-40 hidden flex h-12 w-12 items-center justify-center bg-primary/90 backdrop-blur-md text-primary-foreground rounded-full shadow-xl hover:bg-primary transition-all hover:scale-105 cursor-pointer"
  aria-label="Scroll to top"
>
  <Icon name="arrow-up" class="w-6 h-6 transform -translate-y-[1px]" />
</button>

<script>
  const scrollToTopButton = document.querySelector('[data-scroll-to-top]');

  const toggleScrollToTop = () => {
    scrollToTopButton?.classList.toggle('hidden', window.scrollY <= 500);
  };

  toggleScrollToTop();
  window.addEventListener('scroll', toggleScrollToTop, { passive: true });
</script>
